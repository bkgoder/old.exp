{
  "name": "Zero-Token-Explotion",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:1-22-bookworm",
  "remoteUser": "node",
  "postCreateCommand": "bash ./setup.sh --devcontainer",
  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash"
      },
      "extensions": [
        "github.copilot",
        "github.copilot-chat",
        "ms-azuretools.vscode-containers"
      ]
    }
  }
}